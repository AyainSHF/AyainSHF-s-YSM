{
  "spec": 2,
  "metadata": {
    "name": "牛牧朱莉",
    "tips": "负责歌赫娜学园的食堂管理的供餐部成员。虽然是为了和枫香前辈和学生们而努力做饭的努力派少女，可由于经她之手的菜品疑似会受到亚空间四神的祝福，所以在配餐方面并没有什么帮助。但是在枫香的鼓励和指导下，她今天也为了做出更好的料理而努力着。",
    "license": {
      "type": "CC BY-NC-SA 4.0"
    },
    "authors": [
      {
        "name": "筅袔",
        "role": "模型&额外动画",
        "avatar": "avatar/xh.png",
        "contact": {
          "Bilibili": "https://space.bilibili.com/13098279"
        },
        "comment": "设计蚂蚁真好听(B站获取长期更新链接)"
      },
      {
        "name": "蔚蓝档案",
        "role": "IP",
        "avatar": "avatar/ba.png",
        "contact": {
          "官网": "https://bluearchive-cn.com"
        },
        "comment": "你说得对但是布鲁啊凯芜是一款后面的忘了"
      }
    ]
  },
  "properties": {
    "height_scale": 0.7,
    "width_scale": 0.7,
    "extra_animation": {
      "extra30": "#extra_config",
      "extra1": "挥手",
      "extra2": "拍手",
      "extra3": "点头",
      "extra4": "摇头",
      "extra5": "加油！",
      "extra6": "摆手摇",
      "extra60": "#bj_config",
      "extra7": "机械舞",
      "extra0": "诹访大舞"
    },
    "extra_animation_buttons": [
      {
        "id": "extra_config",
        "name": "\u00a79模型设置",
        "config_forms": [
          {
            "type": "range",
            "title": "模型缩放修正：",
            "description": "碰撞箱及视角不变，\u00a7m并非个人缩放装置",
            "value": "v.player_size",
            "step": 0.1,
            "min": 0.1,
            "max": 10
          },
          {
            "type": "range",
            "title": "模型高度修正：",
            "description": "\u00a7m用于适配动画以及各种各样高度的椅子",
            "value": "v.player_att",
            "step": 1,
            "min": -20,
            "max": 20
          },
          {
            "type": "checkbox",
            "title": "鞘翅显示",
            "description": "用来显示或隐藏鞘翅",
            "value": "v.qiaochi"
          },
          {
            "type": "checkbox",
            "title": "副手手枪显示",
            "description": "适用于TAC/TACZ",
            "value": "v.shouqiang"
          },
          {
            "type": "checkbox",
            "title": "副手长枪显示",
            "description": "适用于TAC/TACZ",
            "value": "v.changqiang"
          },
          {
            "type": "radio",
            "title": "服装切换",
            "description": "",
            "value": "v.fu",
            "labels": {
                "工作服": "v.fu=0;v.fu_1=1;v.fu_2=1;v.fu_3=0",
                "校服": "v.fu=1;v.fu_1=1;v.fu_2=0;v.fu_3=0",
                "打工": "v.fu=2;v.fu_1=0;v.fu_2=0;v.fu_3=1"
              }
          },
          {
              "type": "radio",
              "title": "表情切换",
              "description": "",
              "value": "v.eye",
              "labels": {
                  "默认": "v.eye=0;v.eye_1=1;v.eye_2=0;v.eye_3=0",
                  "开心": "v.eye=1;v.eye_1=0;v.eye_2=1;v.eye_3=0",
                  "哭哭": "v.eye=2;v.eye_1=0;v.eye_2=0;v.eye_3=1"
              }
           }  
        ]
      },
      {
         "id": "bj_config",
        "name": "\u00a79饼酱头饰设置",
        "config_forms": [
          {
            "type": "checkbox",
            "title": "饼酱显示",
            "description": "用来显示或隐藏饼酱",
            "value": "v.bj"
          },
           {
            "type": "range",
            "title": "饼酱缩放修正：",
            "description": "\u00a7m饼酱总力战可能性微存",
            "value": "v.bj_s",
            "step": 0.5,
            "min": 0.1,
            "max": 100
          },
          {
            "type": "range",
            "title": "饼酱位置修正（x）",
            "description": "\u00a7m用来覆盖食物模型（小声）",
            "value": "v.bj_x",
            "step": 1,
            "min": -100,
            "max": 100
          },
          {
            "type": "range",
            "title": "饼酱位置修正（y）",
            "description": "\u00a7m用来覆盖食物模型（小声）",
            "value": "v.bj_y",
            "step": 1,
            "min": -100,
            "max": 100
          },
          {
            "type": "range",
            "title": "饼酱位置修正（z）",
            "description": "\u00a7m用来覆盖食物模型（小声）",
            "value": "v.bj_z",
           "step": 1,
            "min": -100,
            "max": 100
          },
          {
            "type": "radio",
            "title": "口味切换",
            "description": "",
            "value": "v.bj_a",
            "labels": {
                "原味": "v.bj_a=0;v.bj_c=1;v.bj_p=0",
                "薄荷味": "v.bj_a=1;v.bj_c=0;v.bj_p=1"
              }
          }
        ]
      }
    ],
    "extra_animation_classify": [],
    "preview_animation": "zhanshi",
    "disable_preview_rotation": true,
    "default_texture": "default",
    "render_layers_first": false,
    "free": true
  },
  "files": {
    "player": {
      "model": {
        "main": "models/juri.json",
        "arm": "models/arm.json"
      },
      "animation": {
        "main": "animations/main.animation.json",
        "arm": "animations/arm.animation.json",
        "extra": "animations/extra.animation.json",
        "tac": "animations/tac.animation.json",
        "carryon": "animations/carryon.animation.json",
        "parcool": "animations/parcool.animation.json",
        "swem": "animations/swem.animation.json",
        "slashblade": "animations/slashblade.animation.json",
        "tlm": "animations/tlm.animation.json"
      },
      "animation_controllers": [],
      "texture": [
        "textures/default.png"
      ],
      "sound_path": "sounds"
    },
    "arrow": {
      "model": "models/arrow.json",
      "animation": "animations/arrow.animation.json",
      "texture": "textures/arrow.png"
    }
  }
}