{
  "spec": 2,
  "metadata": {
    "name": "箱部鸣",
    "tips": "彩绿的贝斯担当。尽管个子小小的，但在Live上会用破天荒的演出和异想天开的表现引人注目，是乐队的头号特攻队长！尽管是个时不时翘课搞一些奇怪企划的捣蛋鬼，但有很多乐队伙伴，也是真心喜欢音乐。除了音乐对游戏和动画也很了解，总之是乐队里玩心最重的一个人。",
    "license": {
      "type": "CC 0"
    },
    "authors": [
      {
        "name": "筅袔",
        "role": "模型&额外动画",
        "avatar": "avatar/xh.png",
        "contact": {
          "Bilibili": "https://space.bilibili.com/13098279"
        },
        "comment": "音击flower真好听(B站获取长期更新链接)"
      },
      {
        "name": "イロドリミドリ（彩绿）",
        "role": "IP",
        "avatar": "avatar/im.png",
        "contact": {
          "官网": "https://chunithm.sega.jp/irodorimidori/"
        },
        "comment": "诞生于世嘉的音乐游戏CHUNITHM的原创女子乐队企划"
      }
    ]
  },
  "properties": {
    "height_scale": 0.7,
    "width_scale": 0.7,
    "extra_animation": {
      "extra1": "挥手",
      "extra2": "拍手",
      "extra3": "点头",
      "extra4": "摇头",
      "extra5": "加油！",
      "extra6": "摆手摇",
      "extra7": "机械舞",
      "extra0": "诹访大舞",
      "bass": "弹贝斯",
      "extra30": "#extra_config1",
      "extra31": "#extra_config2"
    },
    "extra_animation_buttons": [
      {
        "id": "extra_config1",
        "name": "\u00a79服装切换",
        "config_forms": [
          {
            "type": "checkbox",
            "title": "猫耳",
            "description": "所有服装通用",
            "value": "v.maoer"
          },
          {
            "type": "radio",
            "title": "naru的衣柜",
            "description": "\u00A7m\u00A7o黑见芹香是什么歌",
            "value": "v.fu",
            "labels": {
                "舞高校服": "v.fu=0;v.fu_1=1;v.fu_2=0;v.fu_3=0;v.fu_4=0",
                "SnowColoredScore": "v.fu=1;v.fu_1=0;v.fu_2=1;v.fu_3=0;v.fu_4=0",
                "打ち上げフィーバー！": "v.fu=2;v.fu_1=0;v.fu_2=0;v.fu_3=1;v.fu_4=0",
                "阿拜多斯校服（？）": "v.fu=3;v.fu_1=0;v.fu_2=0;v.fu_3=0;v.fu_4=1"
              }
          }
        ]
      },
      {
        "id": "extra_config2",
        "name": "\u00a79模型设置",
        "config_forms": [
          {
            "type": "range",
            "title": "模型缩放修正：",
            "description": "碰撞箱及视角不变，\u00a7m并非个人缩放装置",
            "value": "v.player_size",
            "step": 0.1,
            "min": 0.1,
            "max": 10
          },
          {
            "type": "range",
            "title": "模型高度修正：",
            "description": "\u00a7m用于适配动画以及各种各样高度的椅子",
            "value": "v.player_att",
            "step": 1,
            "min": -20,
            "max": 20
          },
          {
            "type": "checkbox",
            "title": "鞘翅显示",
            "description": "用来显示或隐藏鞘翅",
            "value": "v.qiaochi"
          },
          {
            "type": "checkbox",
            "title": "副手手枪显示",
            "description": "适用于TAC/TACZ/卓越前线",
            "value": "v.shouqiang"
          },
          {
            "type": "checkbox",
            "title": "副手长枪显示",
            "description": "适用于TAC/TACZ/卓越前线",
            "value": "v.changqiang"
          }
          
        ]
      }
    ],
    "extra_animation_classify": [],
    "preview_animation": "gui",
    "disable_preview_rotation": true,
    "gui_no_lighting": false,
    "gui_background": "textures/gui/background.png",
    "default_texture": "default",
    "render_layers_first": false,
    "free": true
  },
  "files": {
    "player": {
      "model": {
        "main": "models/naru.json",
        "arm": "models/arm.json"
      },
      "animation": {
        "main": "animations/main.animation.json",
        "arm": "animations/arm.animation.json",
        "extra": "animations/extra.animation.json",
        "tac": "animations/tac.animation.json",
        "carryon": "animations/carryon.animation.json",
        "parcool": "animations/parcool.animation.json",
        "swem": "animations/swem.animation.json",
        "slashblade": "animations/slashblade.animation.json",
        "tlm": "animations/tlm.animation.json",
        "fp_arm": "animations/fp.arm.animation.json"
      },
      "animation_controllers": [],
      "texture": ["textures/default.png"]
    },
    "projectiles": [
      {
        "match": ["minecraft:arrow"],
        "model": "models/arrow.json",
        "animation": "animations/arrow.animation.json",
        "texture": "textures/arrow.png"
      },
      {
        "match": ["minecraft:trident"],
        "model": "models/trident.json",
        "texture": "textures/trident.png"
      },
      {
        "match": ["minecraft:fishing_bobber"],
        "model": "models/fishing_bobber.json",
        "texture": "textures/fishing_bobber.png"
      },
      {
        "match": ["minecraft:firework_rocket"],
        "model": "models/firework_rocket.json",
        "texture": "textures/firework_rocket.png"
      }
    ],
    "vehicles": [],
    "sound_path": "sounds"
  }
}