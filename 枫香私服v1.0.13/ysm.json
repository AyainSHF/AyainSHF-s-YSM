{
  "spec": 2,
  "metadata": {
    "name": "爱清枫香(常服)",
     "tips": "一向忙碌的枫香终于获得了久违的假期，脱下了围裙穿着自己喜欢的衣服，打算趁着这个难得的机会好好放松一下。",
     "license": {
       "type": "CC BY-NC-SA 4.0"
     },
     "authors": [
       {
         "name": "筅袔",
         "role": "模型&额外动画",
         "avatar": "avatar/xh.png",
         "contact": {
           "Bilibili": "https://space.bilibili.com/13098279"
         },
         "comment": "光光看大雷真好听"
      }
    ] 
  },
  "properties": {
    "height_scale": 0.7,
    "width_scale": 0.7,
    "extra_animation": {
      "extra30": "#extra_config",
      "extra0": "诹访大舞",
      "extra1": "挥手",
      "extra2": "拍手",
      "extra3": "点头",
      "extra4": "摇头",
      "extra5": "加油！",
      "extra6": "摆手摇",
      "extra7": "机械舞",
      "extra8": "立绘姿势"
    },
    "extra_animation_buttons": [
      {
        "id": "extra_config",
        "name": "\u00a79模型设置",
        "config_forms": [
          {
            "type": "range",
            "title": "模型缩放修正：",
            "description": "碰撞箱及视角不变，\u00a7m并非个人缩放装置",
            "value": "v.player_size",
            "step": 0.1,
            "min": 0.1,
            "max": 10
          },
          {
            "type": "range",
            "title": "模型高度修正：",
            "description": "\u00a7m用于适配动画以及各种各样高度的椅子",
            "value": "v.player_att",
            "step": 1,
            "min": -20,
            "max": 20
          },
          {
            "type": "checkbox",
            "title": "帽子",
            "description": "用来显示或隐藏帽子",
            "value": "v.hat_p7"
          },
          {
            "type": "checkbox",
            "title": "副手手枪显示",
            "description": "适用于TAC/TACZ",
            "value": "v.shouqiang"
          },
          {
            "type": "checkbox",
            "title": "副手长枪显示",
            "description": "适用于TAC/TACZ",
            "value": "v.changqiang"
          },
          {
            "type": "checkbox",
            "title": "鞘翅显示",
            "description": "用来显示或隐藏鞘翅",
            "value": "v.qiaochi"
          },
          {
            "type": "radio",
            "title": "表情切换",
            "description": "",
            "value": "v.face",
            "labels": {
                "通常": "v.face=0;v.face_1=1;v.face_2=0;v.face_3=0",
                "笑容": "v.face=1;v.face_1=0;v.face_2=1;v.face_3=0",
                "哭哭": "v.face=2;v.face_1=0;v.face_2=0;v.face_3=1"
              }
            }
        ]
      }
    ],
    "extra_animation_classify": [],
    "preview_animation": "chuchang",
    "disable_preview_rotation": true,
    "default_texture": "default",
    "render_layers_first": false,
    "free": true
  },
  "files": {
    "player": {
      "model": {
        "main": "models/fuukasf.json",
        "arm": "models/arm.json"
      },
      "animation": {
        "main": "animations/main.animation.json",
        "arm": "animations/arm.animation.json",
        "extra": "animations/extra.animation.json",
        "tac": "animations/tac.animation.json",
        "carryon": "animations/carryon.animation.json",
        "parcool": "animations/parcool.animation.json",
        "swem": "animations/swem.animation.json",
        "slashblade": "animations/slashblade.animation.json"
      },
      "animation_controllers": [],
      "texture": [
        "textures/default.png"
      ],
      "sound_path": "sounds"
    },
    "arrow": {
      "model": "models/arrow.json",
      "animation": "animations/arrow.animation.json",
      "texture": "textures/arrow.png"
    }
  }
}